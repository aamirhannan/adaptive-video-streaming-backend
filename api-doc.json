    "res": {
      "200": {
        "video": {
          "videoId": "64f1a2b3c4d5e6f7890abcdef",
          "status": "ready",
          "updatedAt": "2026-03-30T12:00:00.000Z"
        }
      },
      "400": { "message": "Status is required | videoId is required" },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" },
      "404": { "message": "Video not found" }
    }
  },
  "DELETE - http://localhost:5000/api/videos/:videoId": {
    "notes": "Roles: editor, admin. Editor can delete only their own videos; admin can delete any. Deletion removes the video document, all share assignments for that video, and stored files (original + variants) from object storage.",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>"
      },
      "params": {
        "videoId": "video document videoId"
      }
    },
    "res": {
      "204": "empty body",
      "400": { "message": "videoId is required" },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" },
      "404": { "message": "Video not found" }
    }
  },
  "Socket.io - realtime (same host as API, port as HTTP)": {
    "notes": "Connect with JWT in handshake auth: { token: '<JWT>' }. Server joins socket to room userId.",
    "clientEvents": {
      "connect": "standard",
      "disconnect": "standard"
    },
    "serverEvents": {
      "video:progress": {
        "videoId": "string",
        "phase": "layout | sensitivityAnalysis | transcode_240 | transcode_480 | transcode_720 | ...",
        "progress": "number 0-100",
        "status": "uploaded | processing | ready | flagged | failed"
      },
      "video:status": {
        "videoId": "string",
        "status": "ready | flagged | ...",
        "sensitivity": "safe | flagged"
      },
      "video:error": {
        "videoId": "string",
        "status": "failed"
      }
    }
  }
}
