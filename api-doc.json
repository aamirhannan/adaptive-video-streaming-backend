            {
              "quality": "480",
              "height": 480,
            "storagePath": "videos/<videoId>/480.mp4",
              "sizeBytes": 900000
            },
            {
              "quality": "720",
              "height": 720,
            "storagePath": "videos/<videoId>/720.mp4",
              "sizeBytes": 1500000
            }
          ],
          "analysisSummary": "durationSec=...; hasVideo=true; blackRatio=...; sensitivity=safe",
          "createdAt": "2026-03-30T12:00:00.000Z",
          "updatedAt": "2026-03-30T12:00:00.000Z"
        }
