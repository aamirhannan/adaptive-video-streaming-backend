  "POST - http://localhost:5000/api/videos/:videoId/shares": {
    "notes": "Roles: editor, admin. Editor may share only videos they own; admin may share any video. Target user must exist and have role viewer. Request accepts either userId or email for the target viewer. Creates an assignment so that viewer can list, get metadata, and stream the video.",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>"
      },
      "params": {
        "videoId": "video document videoId"
      },
      "body": {
        "sharedWith": "required: target viewer identifier (userId OR email)",
        "sharedWithUserId": "optional legacy field: target viewer userId",
        "sharedWithEmail": "optional legacy field: target viewer email"
      }
    },
    "res": {
      "201": {
        "share": {
          "shareId": "64f1a2b3c4d5e6f7890abcdef",
          "videoId": "64f1a2b3c4d5e6f7890abcdef",
          "sharedWithUserId": "64f1a2b3c4d5e6f7890abcdef",
          "sharedByUserId": "64f1a2b3c4d5e6f7890abcdef",
          "createdAt": "2026-03-30T12:00:00.000Z",
          "updatedAt": "2026-03-30T12:00:00.000Z"
        }
      },
      "400": { "message": "sharedWith is required (userId or email) | Cannot share with yourself | Target user is already the video owner | Video can only be shared with users who have the viewer role" },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" },
      "404": { "message": "Video not found | Target user not found" },
      "409": { "message": "Video is already shared with this user" }
    }
  },
  "GET - http://localhost:5000/api/videos/:videoId/shares": {
    "notes": "Roles: editor, admin. Lists share records for this video. Editor only if they own the video; admin for any video.",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>"
      },
      "params": {
        "videoId": "video document videoId"
      }
    },
    "res": {
      "200": {
        "shares": [
          {
            "shareId": "64f1a2b3c4d5e6f7890abcdef",
            "videoId": "64f1a2b3c4d5e6f7890abcdef",
            "sharedWithUserId": "64f1a2b3c4d5e6f7890abcdef",
            "sharedByUserId": "64f1a2b3c4d5e6f7890abcdef",
            "createdAt": "2026-03-30T12:00:00.000Z",
            "updatedAt": "2026-03-30T12:00:00.000Z"
          }
        ]
      },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" },
      "404": { "message": "Video not found" }
    }
  },
  "DELETE - http://localhost:5000/api/videos/:videoId/shares/:shareId": {
    "notes": "Roles: editor, admin. Revokes a share. Editor only for videos they own; admin for any video.",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>"
      },
      "params": {
        "videoId": "video document videoId",
        "shareId": "share document shareId"
      }
    },
    "res": {
      "204": "empty body",
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" },
      "404": { "message": "Video not found | Share not found" }
    }
  },
  "GET - http://localhost:5000/api/videos/:videoId/stream": {
    "notes": "Accessible if owner or video is shared with the user. After processing, streams one of three FFmpeg-encoded MP4 renditions (240p, 480p, 720p) stored in Fly Tigris object storage. Default quality=720. Supports HTTP Range (206 Partial Content) for chunked delivery; HTML video uses this via Range. Auth: either Authorization Bearer OR query access_token=<JWT> (for <video src> which cannot send headers). Viewers cannot stream flagged videos. Body is raw video bytes.",
    "req": {
      "headers": {
        "Authorization": "optional: Bearer <JWT_TOKEN> (omit if using access_token query)",
        "Range": "optional: bytes=start-end (browser sends for partial content)"
      },
      "query": {
        "quality": "optional: 240 | 480 | 720 (default 720)",
        "access_token": "optional: JWT — same as Bearer; use for native video element streaming"
      },
      "params": {
        "videoId": "video document videoId"
      }
    },
    "res": {
      "200": {
        "headers": {
          "Content-Type": "video/mp4 (or stored mime)",
          "Content-Length": "<file size>",
          "Accept-Ranges": "bytes"
        },
        "body": "<binary video>"
      },
      "206": {
        "headers": {
          "Content-Range": "bytes start-end/total",
          "Content-Length": "<chunk size>",
          "Content-Type": "video/mp4",
          "Accept-Ranges": "bytes"
        },
        "body": "<binary chunk>"
      },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Flagged content is restricted for viewer role | Forbidden" },
      "404": { "message": "Video not found | Video file not found | Requested quality is not available" },
      "400": { "message": "quality must be 240, 480, or 720" },
      "409": { "message": "Video is not ready for streaming" },
      "416": { "message": "Invalid range" }
    }
  },
  "PATCH - http://localhost:5000/api/videos/:videoId/status": {
    "notes": "Admin only.",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>"
      },
      "params": {
        "videoId": "video document videoId"
      },
      "body": {
        "status": "uploaded | processing | ready | flagged | failed"
      }
