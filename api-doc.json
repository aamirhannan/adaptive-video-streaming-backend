{
  "POST - http://localhost:5000/api/auth/register": {
    "req": {
      "body": {
        "email": "test@example.com",
        "password": "strongpassword123",
        "role": "optional: 'admin' | 'editor' | 'viewer' (defaults to viewer in schema if omitted)"
      }
    },
    "res": {
      "201": {
        "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
        "user": {
          "userId": "64f1a2b3c4d5e6f7890abcdef",
          "email": "test@example.com",
          "role": "viewer"
        }
      },
      "409": { "message": "Email already exists" }
    }
  },
  "POST - http://localhost:5000/api/auth/login": {
    "req": {
      "body": {
        "email": "test@example.com",
        "password": "strongpassword123"
      }
    },
    "res": {
      "200": {
        "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
        "user": {
          "userId": "64f1a2b3c4d5e6f7890abcdef",
          "email": "test@example.com",
          "role": "viewer"
        }
      },
      "401": { "message": "Invalid credentials" }
    }
  },
  "GET - http://localhost:5000/api/auth/me": {
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>"
      }
    },
    "res": {
      "200": {
        "user": {
          "userId": "64f1a2b3c4d5e6f7890abcdef",
          "email": "test@example.com",
          "role": "viewer"
        }
      },
      "401": { "message": "Unauthorized" },
      "404": { "message": "User not found" }
    }
  },
  "POST - http://localhost:5000/api/videos/upload": {
    "notes": "Roles: editor, admin. Multipart form field name: video",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>",
        "Content-Type": "multipart/form-data"
      },
      "body": "form field 'video' (file); allowed types include video/mp4, video/quicktime, video/webm, video/x-matroska; max size 200MB"
    },
    "res": {
      "201": {
        "video": {
          "videoId": "64f1a2b3c4d5e6f7890abcdef",
          "ownerUserId": "64f1a2b3c4d5e6f7890abcdef",
          "originalName": "clip.mp4",
          "storedFileName": "1730000000000-123456789.mp4",
          "storagePath": "<absolute path under storage/videos>",
          "mimeType": "video/mp4",
          "sizeBytes": 1048576,
          "status": "uploaded",
          "sensitivity": "unknown",
          "progress": 0,
          "createdAt": "2026-03-30T12:00:00.000Z",
          "updatedAt": "2026-03-30T12:00:00.000Z"
        }
      },
      "400": { "message": "Video file is required | Unsupported video format" },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" }
    }
  },
  "GET - http://localhost:5000/api/videos": {
    "notes": "Roles: viewer, editor, admin. Lists videos owned by the authenticated user.",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>"
      },
      "query": {
        "status": "optional: uploaded | processing | ready | flagged | failed",
        "sensitivity": "optional: safe | flagged | unknown"
      }
    },
    "res": {
      "200": {
        "videos": [
          {
            "videoId": "64f1a2b3c4d5e6f7890abcdef",
            "ownerUserId": "64f1a2b3c4d5e6f7890abcdef",
            "originalName": "clip.mp4",
            "storedFileName": "1730000000000-123456789.mp4",
            "storagePath": "<path>",
            "mimeType": "video/mp4",
            "sizeBytes": 1048576,
            "status": "ready",
            "sensitivity": "safe",
            "progress": 100,
            "createdAt": "2026-03-30T12:00:00.000Z",
            "updatedAt": "2026-03-30T12:00:00.000Z"
          }
        ]
      },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" }
    }
  },
  "GET - http://localhost:5000/api/videos/:videoId": {
    "notes": "Owner-only (JWT userId must match video ownerUserId).",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>"
      },
      "params": {
        "videoId": "video document videoId"
      }
    },
    "res": {
      "200": {
        "video": {
          "videoId": "64f1a2b3c4d5e6f7890abcdef",
          "ownerUserId": "64f1a2b3c4d5e6f7890abcdef",
          "originalName": "clip.mp4",
          "storedFileName": "1730000000000-123456789.mp4",
          "storagePath": "<path>",
          "mimeType": "video/mp4",
          "sizeBytes": 1048576,
          "status": "ready",
          "sensitivity": "safe",
          "progress": 100,
          "errorMessage": "optional string if failed",
          "createdAt": "2026-03-30T12:00:00.000Z",
          "updatedAt": "2026-03-30T12:00:00.000Z"
        }
      },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" },
      "404": { "message": "Video not found" }
    }
  },
  "GET - http://localhost:5000/api/videos/:videoId/stream": {
    "notes": "Owner-only. Supports HTTP Range (206 Partial Content). Viewers cannot stream flagged videos. Body is raw video bytes.",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>",
        "Range": "optional: bytes=start-end"
      },
      "params": {
        "videoId": "video document videoId"
      }
    },
    "res": {
      "200": {
        "headers": {
          "Content-Type": "video/mp4 (or stored mime)",
          "Content-Length": "<file size>",
          "Accept-Ranges": "bytes"
        },
        "body": "<binary video>"
      },
      "206": {
        "headers": {
          "Content-Range": "bytes start-end/total",
          "Content-Length": "<chunk size>",
          "Content-Type": "video/mp4",
          "Accept-Ranges": "bytes"
        },
        "body": "<binary chunk>"
      },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Flagged content is restricted for viewer role | Forbidden" },
      "404": { "message": "Video not found | Video file not found" },
      "409": { "message": "Video is not ready for streaming" },
      "416": { "message": "Invalid range" }
    }
  },
  "PATCH - http://localhost:5000/api/videos/:videoId/status": {
    "notes": "Admin only.",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>"
      },
      "params": {
        "videoId": "video document videoId"
      },
      "body": {
        "status": "uploaded | processing | ready | flagged | failed"
      }
    },
    "res": {
      "200": {
        "video": {
          "videoId": "64f1a2b3c4d5e6f7890abcdef",
          "status": "ready",
          "updatedAt": "2026-03-30T12:00:00.000Z"
        }
      },
      "400": { "message": "Status is required | videoId is required" },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" },
      "404": { "message": "Video not found" }
    }
  },
  "Socket.io - realtime (same host as API, port as HTTP)": {
    "notes": "Connect with JWT in handshake auth: { token: '<JWT>' }. Server joins socket to room userId.",
    "clientEvents": {
      "connect": "standard",
      "disconnect": "standard"
    },
    "serverEvents": {
      "video:progress": {
        "videoId": "string",
        "phase": "uploaded | metadataValidation | sensitivityAnalysis | streamReady",
        "progress": "number 0-100",
        "status": "uploaded | processing | ready | flagged | failed"
      },
      "video:status": {
        "videoId": "string",
        "status": "ready | flagged | ...",
        "sensitivity": "safe | flagged"
      },
      "video:error": {
        "videoId": "string",
        "status": "failed"
      }
    }
  }
}
