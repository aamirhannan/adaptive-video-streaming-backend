  "GET - http://localhost:5000/api/admin/users": {
    "notes": "Admin only. Lists all users (no passwords).",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN_admin>"
      }
    },
    "res": {
      "200": {
        "users": [
          {
            "userId": "64f1a2b3c4d5e6f7890abcdef",
            "email": "user@example.com",
            "role": "viewer",
            "createdAt": "2026-03-30T12:00:00.000Z",
            "updatedAt": "2026-03-30T12:00:00.000Z"
          }
        ]
      },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" }
    }
  },
  "PATCH - http://localhost:5000/api/admin/users/:userId/role": {
    "notes": "Admin only. Updates the target user's role.",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN_admin>"
      },
      "params": {
        "userId": "target user userId"
      },
      "body": {
        "role": "admin | editor | viewer"
      }
    },
    "res": {
      "200": {
        "user": {
          "userId": "64f1a2b3c4d5e6f7890abcdef",
          "email": "user@example.com",
          "role": "editor",
          "createdAt": "2026-03-30T12:00:00.000Z",
          "updatedAt": "2026-03-30T12:00:00.000Z"
        }
      },
      "400": { "message": "userId is required | role is required and must be admin, editor, or viewer" },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" },
      "404": { "message": "User not found" }
    }
  },
  "POST - http://localhost:5000/api/videos/upload": {
    "notes": "Roles: editor, admin. Multipart form field name: video. Upload is processed locally then stored in Fly Tigris object storage.",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>",
        "Content-Type": "multipart/form-data"
      },
      "body": "form field 'video' (file); allowed types include video/mp4, video/quicktime, video/webm, video/x-matroska; max size 20MB"
    },
    "res": {
      "201": {
        "video": {
          "videoId": "64f1a2b3c4d5e6f7890abcdef",
          "ownerUserId": "64f1a2b3c4d5e6f7890abcdef",
          "ownerEmail": "editor@example.com",
          "originalName": "clip.mp4",
          "storedFileName": "1730000000000-123456789.mp4",
          "storagePath": "videos/<videoId>/original.<ext> (Tigris object key)",
          "mimeType": "video/mp4",
          "sizeBytes": 1048576,
          "status": "uploaded",
          "sensitivity": "unknown",
          "progress": 0,
          "createdAt": "2026-03-30T12:00:00.000Z",
          "updatedAt": "2026-03-30T12:00:00.000Z"
        }
      },
      "400": { "message": "Video file is required | Unsupported video format" },
      "413": { "message": "Video file size must be 20MB or less" },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" }
    }
  },
  "GET - http://localhost:5000/api/videos": {
    "notes": "Roles: viewer, editor, admin. Lists videos owned by the user plus videos shared with them (assigned viewers).",
    "req": {
      "headers": {
        "Authorization": "Bearer <JWT_TOKEN>"
      },
      "query": {
        "status": "optional: uploaded | processing | ready | flagged | failed",
        "sensitivity": "optional: safe | flagged | unknown"
      }
    },
    "res": {
      "200": {
        "videos": [
          {
            "videoId": "64f1a2b3c4d5e6f7890abcdef",
            "ownerUserId": "64f1a2b3c4d5e6f7890abcdef",
            "ownerEmail": "editor@example.com",
            "originalName": "clip.mp4",
            "storedFileName": "1730000000000-123456789.mp4",
            "storagePath": "<path>",
            "mimeType": "video/mp4",
            "sizeBytes": 1048576,
            "status": "ready",
            "sensitivity": "safe",
            "progress": 100,
            "createdAt": "2026-03-30T12:00:00.000Z",
            "updatedAt": "2026-03-30T12:00:00.000Z"
          }
        ]
      },
      "401": { "message": "Unauthorized" },
      "403": { "message": "Forbidden" }
    }
  },
  "GET - http://localhost:5000/api/videos/:videoId": {
